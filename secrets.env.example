# Copy this file to `secrets.env` and fill in your values.
# secrets.env is gitignored — never commit real credentials.
#
# Telegram push alerts (optional). With both set, every motion event is sent
# to your phone instantly as a photo. Leave blank to disable Telegram.
#
# How to obtain these:
#   1. In Telegram, message @BotFather -> /newbot -> follow prompts -> copy the
#      token it gives you (looks like 123456789:AAH...).
#   2. Message your new bot once (say "hi") so it can message you back.
#   3. Get your chat id: open this URL in a browser (token filled in):
#        https://api.telegram.org/bot<YOUR_TOKEN>/getUpdates
#      and copy the "chat":{"id": <number> } value.

SM_TELEGRAM_BOT_TOKEN=
SM_TELEGRAM_CHAT_ID=

# Optional: minimum seconds between photo pushes during one continuous event
# (every frame is still saved locally + iCloud regardless). Default 30.
# SM_TELEGRAM_MIN_INTERVAL=30
